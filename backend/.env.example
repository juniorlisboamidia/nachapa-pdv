# Banco PRÓPRIO do PDV (separado do H360). Mesmo servidor Postgres, database própria.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/operacao"
PORT=4001

# JWT_SECRET: use EXATAMENTE o mesmo segredo do HUB/H360 (login único / SSO).
# Em produção, o valor real vive no ambiente do processo (não commitar).
JWT_SECRET=""

# Origens liberadas no CORS (o subdomínio do PDV em produção). localhost já é liberado.
CORS_ORIGINS="https://pdv.nachapahub.com.br"

# Banco de ORIGEM da cópia inicial (o H360). Usado SÓ pelo script copiar-hamburgao.mjs.
SRC_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hamburgueria360"
